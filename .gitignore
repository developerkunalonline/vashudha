# =============================================================================
# VASHUDHA — Root .gitignore
# Covers both vashudha-backend/ (Python/Flask) and vashudha-frontend/ (Next.js)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# SECRETS & ENVIRONMENT FILES  (NEVER commit these)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
# Note: .env.example is intentionally NOT listed here so it can be committed


# ─────────────────────────────────────────────────────────────────────────────
# PYTHON / FLASK  (vashudha-backend/)
# ─────────────────────────────────────────────────────────────────────────────

# Virtual environment
venv/
.venv/
env/
ENV/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Testing & coverage
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Mypy / type checking
.mypy_cache/
.dmypy.json

# Jupyter
.ipynb_checkpoints/

# PyInstaller
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt


# ─────────────────────────────────────────────────────────────────────────────
# NODE / NEXT.JS  (vashudha-frontend/)
# ─────────────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Next.js build output
.next/
out/

# Production build
build/

# Cache
.cache/
*.tsbuildinfo
next-env.d.ts

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel / deployment
.vercel

# Turbopack
.turbo/


# ─────────────────────────────────────────────────────────────────────────────
# EDITORS & OS
# ─────────────────────────────────────────────────────────────────────────────

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Vim / Emacs swap files
*.swp
*.swo
\#*\#
.\#*


# ─────────────────────────────────────────────────────────────────────────────
# MISC
# ─────────────────────────────────────────────────────────────────────────────

# Logs
logs/
*.log

# Temp files
tmp/
temp/

# Uploads / user-generated content
uploads/
media/
